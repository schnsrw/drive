---
/**
 * /screenshots — flagship UI gallery. Mobile 2-col, tablet 3-col, desktop 4-col.
 * Each tile is an Astro <Image> fallback (regular <img> here since we ship
 * the assets as plain PNG in public/). Click → opens the full-res image
 * in a new tab.
 */
import Base from "../layouts/Base.astro";

const sections = [
  {
    h: "Files",
    shots: [
      { src: "/screenshots/files-light.png", alt: "Files list in light theme" },
      { src: "/screenshots/files-dark.png", alt: "Files list in dark theme" },
      { src: "/screenshots/files-mobile.png", alt: "Files list on mobile" },
    ],
  },
  {
    h: "Editor handoff",
    shots: [
      { src: "/screenshots/editor-xlsx.png", alt: "Casual Sheet opened from Drive" },
      { src: "/screenshots/editor-docx.png", alt: "Casual Document opened from Drive" },
    ],
  },
  {
    h: "Sharing",
    shots: [
      { src: "/screenshots/share-dialog.png", alt: "Share dialog with password + expiry" },
      { src: "/screenshots/share-recipient.png", alt: "Recipient view of a shared file" },
    ],
  },
  {
    h: "Settings + Admin",
    shots: [
      { src: "/screenshots/settings-storage.png", alt: "Settings → Storage with quota readout" },
      { src: "/screenshots/admin-users.png", alt: "Admin → Users management" },
      { src: "/screenshots/audit-log.png", alt: "Audit log with recent events" },
    ],
  },
];
---

<Base
  title="Screenshots"
  description="Every flagship surface of Casual Drive — file list, editor handoff, sharing, settings, admin — in light and dark themes, on desktop and mobile."
>
  <div class="container shots-shell">
    <header class="shots-header">
      <p class="shots-eyebrow">Gallery</p>
      <h1 class="shots-h1">Every surface, real screenshots.</h1>
      <p class="shots-lede">
        Captured straight from the demo. Tap any image to see it full-size.
      </p>
    </header>

    {
      sections.map((s) => (
        <section class="shots-section">
          <h2 class="shots-section-h">{s.h}</h2>
          <ul class="shots-grid" role="list">
            {
              s.shots.map((shot) => (
                <li class="shots-tile">
                  <a href={shot.src} target="_blank" rel="noopener">
                    <img
                      src={shot.src}
                      alt={shot.alt}
                      width="1600"
                      height="1000"
                      loading="lazy"
                      decoding="async"
                      onerror="this.parentNode.parentNode.classList.add('shots-fallback')"
                    />
                    <span class="shots-fallback-msg">{shot.alt}</span>
                  </a>
                  <p class="shots-caption">{shot.alt}</p>
                </li>
              ))
            }
          </ul>
        </section>
      ))
    }
  </div>
</Base>

<style>
  .shots-shell {
    padding: var(--space-12) var(--space-5) var(--space-16);
  }

  @media (min-width: 768px) {
    .shots-shell {
      padding: var(--space-16) var(--space-8) var(--space-24);
    }
  }

  .shots-header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto var(--space-16);
  }

  .shots-eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent-strong);
    margin-bottom: var(--space-3);
  }

  .shots-h1 {
    font-size: var(--text-4xl);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-3);
  }

  @media (min-width: 768px) {
    .shots-h1 {
      font-size: var(--text-5xl);
    }
  }

  .shots-lede {
    color: var(--muted);
    font-size: var(--text-lg);
  }

  .shots-section {
    margin-bottom: var(--space-16);
  }

  .shots-section-h {
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
    color: var(--ink-soft);
    letter-spacing: -0.015em;
  }

  .shots-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .shots-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  @media (min-width: 1280px) {
    .shots-grid {
      grid-template-columns: 1fr 1fr 1fr 1fr;
    }
  }

  .shots-tile {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .shots-tile a {
    display: block;
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--card);
    transition:
      border-color var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }

  .shots-tile a:hover {
    border-color: var(--line-strong);
    transform: translateY(-2px);
  }

  .shots-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  /* Friendly fallback when a screenshot hasn't shipped yet. */
  .shots-fallback-msg {
    display: none;
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    text-align: center;
    color: var(--muted);
    font-size: var(--text-xs);
    background: repeating-linear-gradient(
      45deg,
      var(--bg-subtle),
      var(--bg-subtle) 10px,
      var(--paper-2) 10px,
      var(--paper-2) 20px
    );
  }

  .shots-tile.shots-fallback img {
    display: none;
  }

  .shots-tile.shots-fallback .shots-fallback-msg {
    display: flex;
  }

  .shots-caption {
    font-size: var(--text-xs);
    color: var(--muted);
    line-height: 1.5;
  }
</style>
