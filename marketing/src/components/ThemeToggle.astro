---
/**
 * Light/dark toggle. Persists to localStorage; Base.astro's inline
 * bootstrap reads it before paint.
 */
---

<button
  type="button"
  class="theme-toggle"
  aria-label="Toggle dark mode"
  data-theme-toggle
>
  <svg
    class="theme-icon-sun"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
  </svg>
  <svg
    class="theme-icon-moon"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  const KEY = "cd-marketing-theme";
  const btn = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
  if (btn) {
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const willBeDark = !root.classList.contains("dark");
      root.classList.toggle("dark", willBeDark);
      try {
        localStorage.setItem(KEY, willBeDark ? "dark" : "light");
      } catch {
        /* localStorage unavailable */
      }
    });
  }
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-sm);
    color: var(--ink-soft);
    transition:
      background var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease);
  }

  .theme-toggle:hover {
    background: var(--bg-hover);
    color: var(--ink);
  }

  .theme-icon-sun {
    display: none;
  }
  .theme-icon-moon {
    display: block;
  }

  :global(html.dark) .theme-icon-sun {
    display: block;
  }
  :global(html.dark) .theme-icon-moon {
    display: none;
  }
</style>
