---
/**
 * Casual Drive mark — black rounded square with a cream cloud silhouette.
 * Source of truth: web/src/components/Logo.tsx + web/public/favicon.svg.
 * The square uses `currentColor`; the cloud uses `--mark-fg` (defaults to
 * the brand cream) so callers can recolour either independently.
 */
export interface Props {
  size?: number;
  className?: string;
}
const { size = 32, className } = Astro.props;
const clipId = `cd-mark-${Math.floor(Math.random() * 1e9).toString(36)}`;
---

<svg
  viewBox="0 0 38 38"
  width={size}
  height={size}
  role="img"
  aria-label="Casual Drive"
  class={className}
  style={{ display: "block", color: "var(--ink)" }}
>
  <defs>
    <clipPath id={clipId}>
      <rect width="38" height="38" rx="10"></rect>
    </clipPath>
  </defs>
  <g clip-path={`url(#${clipId})`}>
    <rect width="38" height="38" fill="currentColor"></rect>
    <g fill="var(--mark-fg, var(--paper, #F2F0EA))">
      <circle cx="12" cy="22" r="5"></circle>
      <circle cx="26" cy="22" r="5"></circle>
      <circle cx="19" cy="15" r="7.5"></circle>
      <rect x="12" y="22" width="14" height="5"></rect>
    </g>
  </g>
</svg>
