{
  "name": "casual-drive-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Casual Drive — single-page web UI. React 19 + Vite 7 + TypeScript + Tailwind v4 + Lucide. Built artifacts in dist/ are embedded into the drive binary via rust-embed.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "screenshots": "node tests/e2e/marketing-screenshots.mjs"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@formkit/auto-animate": "^0.9.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "cmdk": "^1.1.1",
    "dompurify": "^3.4.8",
    "lucide-react": "^0.469.0",
    "marked": "^18.0.5",
    "motion": "^12.40.0",
    "radix-ui": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.77.0",
    "sonner": "^2.0.7",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^7.0.0"
  }
}
