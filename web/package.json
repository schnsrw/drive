{
  "name": "casual-drive-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Casual Drive — single-page web UI. React 19 + Vite 7 + TypeScript + Tailwind v4 + Lucide. Built artifacts in dist/ are embedded into the drive binary via rust-embed.",
  "scripts": {
    "dev": "node scripts/copy-embed.mjs && vite",
    "build": "node scripts/copy-embed.mjs && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "screenshots": "node tests/e2e/marketing-screenshots.mjs"
  },
  "dependencies": {
    "@casualoffice/sheets": "^0.11.1",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@formkit/auto-animate": "^0.9.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@schnsrw/docx-js-editor": "^1.1.7",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-bubble-menu": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@tiptap/suggestion": "^3.26.0",
    "@vidstack/react": "^1.15.6",
    "cmdk": "^1.1.1",
    "dompurify": "^3.4.8",
    "lucide-react": "^0.469.0",
    "marked": "^18.0.5",
    "motion": "^12.40.0",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.7",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8",
    "radix-ui": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.77.0",
    "sonner": "^2.0.7",
    "tiptap-markdown": "^0.9.0",
    "vaul": "^1.1.2",
    "vidstack": "^1.15.6",
    "y-prosemirror": "^1.3.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^7.0.0"
  }
}
